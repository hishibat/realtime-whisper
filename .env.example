# OpenAI API key with access to gpt-realtime-whisper.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Shared passphrase required to use this app. Without it, /api/session
# returns 401 and OpenAI is never called — protects your OpenAI quota
# from anonymous visitors of the public deployment.
# Pick something long and random, e.g. `openssl rand -base64 24`.
APP_PASSWORD=change-me-to-a-long-random-string
